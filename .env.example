# Required folder for files generated by the generate_file tool.
# Relative paths resolve from the server working directory.
LOCAL_MCP_FILE_OUTPUT_DIR=~/Downloads/local-mcp

# Optional friendlier alias. Used only when LOCAL_MCP_FILE_OUTPUT_DIR is empty.
# LOCAL_MCP_DOWNLOAD_DIR=~/Downloads/local-mcp

# Optional tool profile for smaller local models.
# full = original complete tools, simple/qwen = fewer simpler tools, both = both sets.
# LOCAL_MCP_TOOL_PROFILE=simple

# Optional: make web_search automatically fetch after search.
# none = search results only, summarize = fetch/summarize top results, fetch_first = fetch top result.
# LOCAL_MCP_WEB_SEARCH_FOLLOW_UP=summarize
# LOCAL_MCP_WEB_SEARCH_FOLLOW_UP_LIMIT=3

# Optional folder for schedule_task automation bundles.
# Falls back to LOCAL_MCP_FILE_OUTPUT_DIR, LOCAL_MCP_DOWNLOAD_DIR, then .tmp/automations.
# LOCAL_MCP_AUTOMATION_DIR=~/Downloads/local-mcp/automations

# Optional safety gate for schedule_task. Installs are ALLOWED by default; set to 0 to
# generate reviewable files only and never modify cron or launchd automatically.
# LOCAL_MCP_ENABLE_SCHEDULER_INSTALL=0
