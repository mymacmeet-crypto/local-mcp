# Required folder for files generated by the generate_file tool.
# Relative paths resolve from the server working directory.
LOCAL_MCP_FILE_OUTPUT_DIR=~/Downloads/local-mcp

# Optional friendlier alias. Used only when LOCAL_MCP_FILE_OUTPUT_DIR is empty.
# LOCAL_MCP_DOWNLOAD_DIR=~/Downloads/local-mcp

# Google Gemini API key. Required by the smart_search tool (web search ->
# Gemini ranks sources -> crawl -> Gemini summary). Get one from Google AI Studio.
# GEMINI_API_KEY=
# Optional Gemini model override (default: gemini-flash-latest).
# GEMINI_MODEL=gemini-flash-latest

# Optional tool profile for smaller local models.
# full = original complete tools, simple/qwen = fewer simpler tools, both = both sets.
# LOCAL_MCP_TOOL_PROFILE=simple
