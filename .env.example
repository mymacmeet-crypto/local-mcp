# Required folder for files generated by the generate_file tool (md/txt/pdf/docx/pptx).
# Relative paths resolve from the server working directory.
LOCAL_MCP_FILE_OUTPUT_DIR=~/Downloads/local-mcp

# Optional friendlier alias. Used only when LOCAL_MCP_FILE_OUTPUT_DIR is empty.
# LOCAL_MCP_DOWNLOAD_DIR=~/Downloads/local-mcp

# LLM backend used by the smart_search tool (web search -> LLM ranks sources ->
# crawl -> LLM summary). "ollama" (default) uses a local Ollama server; "gemini"
# uses the Google Gemini API instead.
# LLM_PROVIDER=ollama

# Local Ollama server used when LLM_PROVIDER=ollama (the default). Requires
# `ollama serve` to be running and OLLAMA_MODEL to be pulled (`ollama pull <model>`).
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b

# Google Gemini API key. Only needed when LLM_PROVIDER=gemini. Get one from
# Google AI Studio.
# GEMINI_API_KEY=
# Optional Gemini model override (default: gemini-flash-latest).
# GEMINI_MODEL=gemini-flash-latest

# Optional tuning for the deep_research tool (iterative multi-source research).
# Defaults shown; each also has a matching per-call parameter.
# LOCAL_MCP_DEEP_RESEARCH_BREADTH=4
# LOCAL_MCP_DEEP_RESEARCH_MAX_ITERATIONS=2
# LOCAL_MCP_DEEP_RESEARCH_MAX_SOURCES=12
# LOCAL_MCP_DEEP_RESEARCH_CANDIDATES_PER_QUERY=8
# LOCAL_MCP_DEEP_RESEARCH_SOURCE_CHARS=12000
# LOCAL_MCP_DEEP_RESEARCH_FOLLOWUP_QUERIES=4

# Optional tool profile for smaller local models.
# full = original complete tools, simple/qwen = fewer simpler tools, both = both sets.
# LOCAL_MCP_TOOL_PROFILE=simple

# Optional settings for the agent-team tools (define_agent_team / run_agent_team).
# Teams are saved as JSON files in this folder (default: .tmp/agent_teams).
# LOCAL_MCP_AGENT_TEAM_DIR=~/Downloads/local-mcp/agent-teams
# Max tool calls each agent may make per run, and max agents per team.
# LOCAL_MCP_AGENT_MAX_TOOL_CALLS=6
# LOCAL_MCP_AGENT_TEAM_MAX_AGENTS=5
# Character cap applied to each tool result fed back to an agent.
# LOCAL_MCP_AGENT_TOOL_RESULT_CHARS=8000
# Sampling temperature for agent runs.
# LOCAL_MCP_AGENT_TEMPERATURE=0.2
